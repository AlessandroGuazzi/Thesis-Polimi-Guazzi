# ============================================================
# NODE AGENT (gRPC + Redis)
# Ruolo: Esecutore di Migrazione Peer-to-Peer sui Nodi
# ============================================================
FROM python:3.9-slim

# Evita il buffering dei log Python
ENV PYTHONUNBUFFERED=1

# 1. Installazione dipendenze di sistema e Buildah
RUN apt-get update && apt-get install -y \
    curl \
    buildah \
    && rm -rf /var/lib/apt/lists/*

# 2. Installazione di Kubectl (Per parlare con il cluster)
RUN curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl" && \
    chmod +x kubectl && mv kubectl /usr/local/bin/

# 3. Installazione Dipendenze Python (gRPC e Redis)
RUN pip install --no-cache-dir grpcio grpcio-tools redis requests

WORKDIR /agent

# 4. Copia del codice sorgente e delle impalcature protobuf
COPY node_agent.py .
COPY checkpoint_transfer_pb2.py .
COPY checkpoint_transfer_pb2_grpc.py .

# 5. Avvio del Demone
CMD ["python", "node_agent.py"]